# HIA Walkthrough — Environment Variables
# Copy this file to .env and fill in your values.

# Database (SQLite for development)
DATABASE_URL=sqlite:///./data/hia.db

# File storage: "local" or "s3"
STORAGE_BACKEND=local
STORAGE_PATH=./data

# Processed data root (ETL output)
DATA_ROOT=./data/processed

# Anthropic API key for the HIA Wizard chat assistant (optional)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Mapbox GL JS token for map rendering (optional)
# Get one at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# Frontend origin for CORS
BASE_URL=http://localhost:3000

# Census Bureau API key for the ACS demographics ETL script (required to run process_acs.py)
# Get one free at https://api.census.gov/data/key_signup.html
# Not read by the backend API at runtime — only by the ETL script.
CENSUS_API_KEY=
